  <property name="styleSheet">
   <string notr="true">/* Style des cases de texte */
QLineEdit {
    background-color: #2b2b2b;
    border: 2px solid #444444;
    border-radius: 6px;
    padding: 8px;
    color: #ffffff;
    font-size: 13px;
}
QLineEdit:focus {
    border: 2px solid #007acc; /* Devient bleu quand on clique dedans */
}

/* Style du bouton */
QPushButton {
    background-color: #007acc;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 10px;
    font-weight: bold;
    font-size: 14px;
}
QPushButton:hover {
    background-color: #0098ff; /* S'allume en bleu clair au survol */
}
QPushButton:pressed {
    background-color: #005999; /* Devient foncé quand on clique */
}

/* Style des listes */
QListWidget {
    background-color: #1e1e1e;
    border: 1px solid #333333;
    border-radius: 8px;
    padding: 5px;
    color: #e0e0e0;
}
/* Style pour le titre du menu */
QLabel {
    color: #007acc;
    font-size: 18px;
    font-weight: bold;
    font-family: 'Segoe UI', Arial, sans-serif;
    letter-spacing: 1px;
    padding-bottom: 5px;
}

/* Style de la liste des plats transformée en tableau de bord moderne */
QListWidget#listMenu {
    background-color: #1e1e1e;
    border: 2px solid #3a3a3a;
    border-radius: 12px;
    padding: 15px;
    color: #ffffff;
    font-size: 15px;
    font-weight: 500;
}

/* Espacement et effet au survol des plats */
QListWidget#listMenu::item {
    background-color: #252526;
    border-left: 4px solid #007acc; /* Petite barre bleue élégante à gauche de chaque plat */
    margin-bottom: 10px;
    padding: 12px 15px;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}

QListWidget#listMenu::item:hover {
    background-color: #2d2d30;
    color: #0098ff;
}</string>
  </property>
